# Neon PostgreSQL connection string (get this from your Neon dashboard)
DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<dbname>?sslmode=require

# Spring Boot JDBC URL (same DB, but in JDBC format)
SPRING_DATASOURCE_URL=jdbc:postgresql://<neon-host>/<dbname>?user=<user>&password=<password>&sslmode=require
SPRING_DATASOURCE_USERNAME=<user>
SPRING_DATASOURCE_PASSWORD=<password>

# JWT secret for auth tokens (change this in production!)
JWT_SECRET=change-this-to-a-secure-random-string

# Base URL used by the mobile app to reach the Spring Boot backend
API_BASE_URL=http://10.0.2.2:8080
